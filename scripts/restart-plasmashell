#!/usr/bin/env bash
set -euo pipefail

if systemctl --user restart plasma-plasmashell.service; then
	echo "Plasmashell restarted via systemd user service."
	exit 0
fi

echo "systemctl restart failed, trying kquitapp6/kstart6 fallback..."
kquitapp6 plasmashell || true
sleep 1
kstart6 plasmashell
echo "Plasmashell restart command completed."
