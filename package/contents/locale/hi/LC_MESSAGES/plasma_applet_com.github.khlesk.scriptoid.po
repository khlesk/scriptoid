msgid "General"
msgstr "सामान्य"

msgid "Tooltip"
msgstr "टूलटिप"

msgid "Command:"
msgstr "कमांड:"

msgid "bash -lc '/path/to/script.sh'"
msgstr "bash -lc '/path/to/script.sh'"

msgid "Open the configured script in the default text editor"
msgstr "कॉन्फ़िगर की गई स्क्रिप्ट को डिफ़ॉल्ट टेक्स्ट एडिटर में खोलें"

msgid "Set the command to a file path like /path/to/script.sh or ~/script.sh to enable editing"
msgstr "संपादन सक्षम करने के लिए कमांड को /path/to/script.sh या ~/script.sh जैसे फ़ाइल पथ पर सेट करें"

msgid "Refresh (s):"
msgstr "रीफ्रेश (से):"

msgid "Tooltip:"
msgstr "टूलटिप:"

msgid "Run command for tooltip text"
msgstr "टूलटिप पाठ के लिए कमांड चलाएँ"

msgid "Default text:"
msgstr "डिफ़ॉल्ट पाठ:"

msgid "Run a command periodically and show its output."
msgstr "किसी कमांड को नियमित अंतराल पर चलाएँ और उसका आउटपुट दिखाएँ।"

msgid "Width mode:"
msgstr "चौड़ाई मोड:"

msgid "Fill available panel space"
msgstr "उपलब्ध पैनल स्थान भरें"

msgid "Padding:"
msgstr "पैडिंग:"

msgid "Font size:"
msgstr "फ़ॉन्ट आकार:"

msgid "Override font size"
msgstr "फ़ॉन्ट आकार बदलें"

msgid "Font family:"
msgstr "फ़ॉन्ट परिवार:"

msgid "Override font family"
msgstr "फ़ॉन्ट परिवार बदलें"

msgid "Hack"
msgstr "Hack"

msgid "Text color:"
msgstr "पाठ रंग:"

msgid "Override theme text color"
msgstr "थीम का पाठ रंग बदलें"

msgid "Monospace:"
msgstr "मोनोस्पेस:"

msgid "Use fixed-width font"
msgstr "नियत-चौड़ाई फ़ॉन्ट उपयोग करें"

msgid "Text align:"
msgstr "पाठ संरेखण:"

msgid "Left"
msgstr "बाएँ"

msgid "Center"
msgstr "मध्य"

msgid "Right"
msgstr "दाएँ"

msgid "Loading…"
msgstr "लोड हो रहा है…"

msgid "No command set"
msgstr "कोई कमांड सेट नहीं है"

msgid "No output"
msgstr "कोई आउटपुट नहीं"

msgid "Command failed"
msgstr "कमांड विफल हुई"
